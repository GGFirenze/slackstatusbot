# Bot token (xoxb-...) — from your Slack app's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token (xapp-...) — from "Basic Information" → "App-Level Tokens"
# Must have the "connections:write" scope
SLACK_APP_TOKEN=xapp-your-app-token

# User token (xoxp-...) — from "OAuth & Permissions", used to reply in your DMs
SLACK_USER_TOKEN=xoxp-your-user-token

# Your Slack member ID (click your profile pic → "..." → "Copy member ID")
OWNER_USER_ID=U0XXXXXXXXX

# Optional: seconds between auto-replies to the same person (default: 3600)
# COOLDOWN_SECONDS=3600
